#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
SKILLS_DIR="$(dirname "$SCRIPT_DIR")/.claude/skills"

echo "astack setup"
echo "==========="

# Create skills dir if needed
mkdir -p "$SKILLS_DIR"

# Create symlinks for each skill
SKILLS=(plan review fix ship browse qa sync-cookies retro context)

for skill in "${SKILLS[@]}"; do
  src="$SCRIPT_DIR/skills/$skill"
  dst="$SKILLS_DIR/$skill"

  if [ -L "$dst" ]; then
    rm "$dst"
  fi

  if [ -e "$src" ]; then
    ln -s "$src" "$dst"
    echo "  linked /$skill"
  else
    echo "  warning: skills/$skill not found, skipping"
  fi
done

# Build browser binary if Bun is available
if command -v bun &>/dev/null; then
  echo ""
  echo "Building browser binary..."
  cd "$SCRIPT_DIR"
  bun install --silent 2>/dev/null || true
  bun run build 2>/dev/null || echo "  (build step skipped — run 'bun run build' manually if /browse fails)"
else
  echo ""
  echo "Note: Bun not found. /browse and /qa require Bun v1.0+."
  echo "Install: curl -fsSL https://bun.sh/install | bash"
fi

echo ""
echo "Done. Add this to CLAUDE.md:"
echo ""
echo "## Astack"
echo "Available skills: /plan, /review, /fix, /ship, /browse, /qa, /sync-cookies, /retro, /context"
echo "Use /browse for all web browsing. Never use mcp__claude-in-chrome__* tools."
echo "If skills stop working: cd ~/.claude/skills/astack && ./setup"
